# WeatherAPI.com API Configuration
# Get your free API key from: https://www.weatherapi.com/
NUXT_PUBLIC_WEATHER_API_KEY=your_api_key_here

# Google Calendar OAuth 2.0 Configuration
# 1. Go to: https://console.cloud.google.com/
# 2. Enable Google Calendar API
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add authorized JavaScript origins: http://localhost:3000
# 5. Copy the Client ID
NUXT_PUBLIC_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
NUXT_PUBLIC_GOOGLE_API_KEY=your_google_api_key_here
NUXT_PUBLIC_GOOGLE_CALENDAR_ID=primary
